    "@nypl/design-system-react-components": "^0.7.2",
    "@nypl/dgx-svg-icons": "^0.3.14",
    "@theme-ui/color": "^0.16.2",
    "@theme-ui/components": "^0.16.2",
    "@theme-ui/match-media": "^0.16.2",
    "@theme-ui/mdx": "^0.16.2",
    "@thepalaceproject/webpub-viewer": "^0.1.0",
    "chalk": "^4.1.0",
    "date-fns": "^4.1.0",
    "deepmerge": "^4.3.1",
    "dompurify": "^3.4.0",
    "downloadjs": "^1.4.7",
    "history": "^4.10.1",
    "i18next": "^23.10.1",
    "js-cookie": "^2.2.1",
    "lodash": "^4.18.1",
    "moment": "^2.30.1",
    "next": "^15.5.15",
    "next-i18next": "^12.1.0",
    "next-transpile-modules": "^10.0.1",
    "node-fetch": "^2.7.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.53.1",
    "react-i18next": "^12.3.1",
    "react-intersection-observer": "^9.13.1",
    "react-redux": "^7.2.9",
    "styled-system": "^5.1.5",
    "swr": "^1.3.0",
    "theme-ui": "^0.16.2",
    "tslib": "^2.8.1"
  },
  "devDependencies": {
    "@axe-core/react": "^4.11.1",
    "@babel/core": "^7.26.0",
    "@fetch-mock/jest": "^0.2.6",
    "@next/bundle-analyzer": "^14.2.35",
    "@next/eslint-plugin-next": "^15.5.15",
    "@storybook/addon-actions": "^8.4.0",
    "@storybook/addon-essentials": "^8.4.0",
    "@storybook/addon-links": "^8.4.0",
    "@storybook/react": "^8.6.12",
    "@testing-library/cypress": "^10.0.2",
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/react-hooks": "^3.7.0",
    "@testing-library/user-event": "^14.5.2",
    "@types/dompurify": "^3.0.5",
    "@types/downloadjs": "^1.4.6",
    "@types/history": "^4.7.11",
    "@types/jest": "^26.0.15",
    "@types/js-cookie": "^2.2.7",
    "@types/node": "^18.19.130",
    "@types/pako": "^1.0.7",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.7",
    "@types/react-redux": "^7.1.34",
    "@types/xml2js": "^0.4.14",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "babel-jest": "^29.7.0",
    "babel-loader": "^8.4.1",
    "cypress": "^13.15.2",
    "eslint": "8.56.0",
    "eslint-config-prettier": "^6.15.0",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-prettier": "^3.4.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^4.6.2",
    "fetch-mock": "^10.1.1",
    "i18next-cli": "^1.5.11",
    "jest": "^29.7.0",
    "jest-emotion": "^10.0.32",
    "jest-environment-jsdom": "^29.7.0",
    "jest-fetch-mock": "^3.0.3",
    "jest-jasmine2": "^29.7.0",
    "msw": "^2.6.5",
    "prettier": "2.1.1",
    "react-is": "^18.2.0",
    "react-test-renderer": "^18.3.1",
    "typescript": "^4.9.5",
    "webpack-bugsnag-plugins": "^1.8.0"
  },
  "overrides": {
    "@typescript-eslint/typescript-estree": {
      "minimatch": "9.0.7"
    },
    "cosmiconfig": {
      "yaml": "1.10.3"
    }
  },
  "prettier": {
    "arrowParens": "avoid",
    "bracketSpacing": true,
    "endOfLine": "auto",
    "htmlWhitespaceSensitivity": "css",
    "insertPragma": false,
    "jsxBracketSameLine": false,
    "jsxSingleQuote": false,
    "printWidth": 80,
    "proseWrap": "preserve",
    "quoteProps": "as-needed",
    "requirePragma": false,
    "semi": true,
    "singleQuote": false,
    "tabWidth": 2,
    "trailingComma": "none",
    "useTabs": false
  }
}
